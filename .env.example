# Environment variable NAMES required by this project. Never put values here.
# Storage locations per CLAUDE.md "Secrets inventory".

# --- Turso ---
# libsql:// URL of the nsw-property database.
# Lives in: GitHub Actions secret + Cloudflare Worker var.
TURSO_DATABASE_URL=

# Full-access token for the weekly sync (writes).
# Lives in: GitHub Actions secret ONLY.
TURSO_WRITE_TOKEN=

# Read-only token for the API.
# Lives in: Cloudflare Worker secret ONLY.
TURSO_READ_TOKEN=

# --- API ---
# Long random bearer token clients must present.
# Lives in: Cloudflare Worker secret + owner's password manager.
API_TOKEN=

# --- Cloudflare R2 (raw ZIP archive) ---
# Lives in: GitHub Actions secrets.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# --- Monitoring ---
# healthchecks.io ping URL for the weekly job.
# Lives in: GitHub Actions secret.
HEALTHCHECK_URL=

# --- Local-only (optional) ---
# Personal access token for the GitHub MCP server; local shell env only.
GITHUB_PAT=
